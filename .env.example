# Clawd — Environment Variables
# cp .env.example .env

# Volcengine API Key (新版控制台统一鉴权，ASR+TTS 共用)
VOLC_TOKEN=your_a...n
# ASR resource ID (可选)
# ASR_RESOURCE_ID=volc.seedasr.sauc.duration

# Hermes API 地址
HERMES_URL=http://localhost:8642

# Hermes API Server Key (本地鉴权)
API_SERVER_KEY=clawd

# 音频设备 (Pi 专用)
# AUDIO_DEV=plughw:2,0
# 录音秒数
# RECORD_SECS=5
