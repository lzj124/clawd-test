# Clawd — Environment Variables
# cp .env.example .env

# Volcengine API Key (新版控制台统一鉴权，ASR+TTS 共用)
VOLC_TOKEN=your_api_key_here

# ASR resource ID (可选，默认即可)
# ASR_RESOURCE_ID=volc.seedasr.sauc.duration

# Hermes LLM API (local gateway)
HERMES_API_KEY=
HERMES_URL=http://localhost:8642/v1/chat/completions
