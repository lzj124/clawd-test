# Clawd — Environment Variables
# cp .env.example .env

# Volcengine ASR (V3) + TTS (2.0)
# 统一 X-Api-Key 鉴权
VOLC_APPID=your_app_id_here
VOLC_TOKEN=your_access_token_here

# ASR resource ID (default is fine for most users)
# ASR_RESOURCE_ID=volc.seedasr.sauc.duration

# Hermes LLM API (local gateway)
HERMES_API_KEY=
HERMES_URL=http://localhost:8642/v1/chat/completions
