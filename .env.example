# Clawd — Environment Variables
# cp .env.example .env

# Volcengine API Key（新版控制台统一鉴权，ASR + TTS 共用）
VOLC_TOKEN=your_app_key_here
# ASR resource ID (可选，默认即可)
# ASR_RESOURCE_ID=volc.seedasr.sauc.duration

# Hermes API Server Key
# 用于本地 API 鉴权，随便设一个即可
API_SERVER_KEY=clawd

# Hermes API 地址（不用改）
HERM...e
